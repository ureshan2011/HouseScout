# ---- HouseScout configuration ----
# Copy to .env and fill in. All values have sensible defaults for local use.

# Database (SQLite by default; swap for a Postgres URL to go multi-user later)
DATABASE_URL=sqlite:///./data/housescout.db

# LINZ Data Service (free) — get a key at https://data.linz.govt.nz/
LINZ_API_KEY=

# LM Studio (OpenAI-compatible local endpoint on your RTX 4080 machine)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
# Name of the loaded chat model (e.g. gemma-3-27b-it). Leave blank to auto-pick the first model.
LMSTUDIO_CHAT_MODEL=
# Embedding model loaded in LM Studio for RAG (e.g. text-embedding-nomic-embed-text-v1.5)
LMSTUDIO_EMBED_MODEL=

# Buyer profile / defaults (Christchurch)
MAX_PRICE=500000
PREAPPROVAL=480000
DEPOSIT=50000
DEFAULT_MORTGAGE_RATE=0.0519
DEFAULT_TERM_YEARS=30
# Weekly rent you expect to charge per boarder room
BOARDER_WEEKLY_RENT=220

# Scraper
SCRAPE_REGION=canterbury
SCRAPE_DISTRICT=christchurch-city
SCRAPE_INTERVAL_HOURS=6
SCRAPE_USER_AGENT=HouseScout/0.1 (personal use)
